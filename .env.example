# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/tapbattle?schema=public"

# Port for the custom Node + Socket.io server
PORT=3000

# Credentials for the /admin dashboard (HTTP Basic Auth)
# Set real values before deploying -- these are NOT safe defaults.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"
